@page "/students/Delete/{id:int}"
@using Application.Services.StudentServices
@using Application.DTOs
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IStudentService StudentService

<div class="container mt-5">
    <EditForm Model="student" OnValidSubmit="RemoveStudent">
        <div class="form-group">
        <label class="btn btn-danger">Are you sure you want to delete this student?</label>
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/students" class="btn btn-secondary">Cancel</a>
        </div>
    </EditForm>
</div>

@code{
    [Parameter]
    public int Id { get; set; }
    private GetStudentDTO? ExistingStudent;
    private DeleteStudentDTO student = new ();
    protected override void OnParametersSet()
    {
        ExistingStudent = StudentService.GetStudentById(Id);
        if (ExistingStudent != null)
        {
            student.Id = ExistingStudent.Id;
        }
    }
    private void RemoveStudent()
    {
        if (student != null)
        {
            StudentService.DeleteStudent(student);
            Navigation.NavigateTo("/students");
        }
    }
}