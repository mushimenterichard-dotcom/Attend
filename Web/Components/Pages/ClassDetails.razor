@page "/classes/{id:int}"
@inject NavigationManager Navigation
@using Application.Services.ClassServices   
@inject IClassService ClassService   
@using Application.DTOs

<h3 class="form-label" >Class Details </h3>
<a href="/classes" class="btn btn-secondary">Back to List</a>

<!-- Class Details Card -->
<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Class Details</h3>
        </div>
        <div class="card-body">
            @if (classess != null)
            {
                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Id:</div>
                    <div class="col-md-8">@classess.Id</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Name:</div>
                    <div class="col-md-8">@classess.Name</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Faculity:</div>
                    <div class="col-md-8">@classess.FacultyId</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Education Level:</div>
                    <div class="col-md-8">@classess.EducationLevelId</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">UserAdded:</div>
                    <div class="col-md-8">@classess.UserAdded</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">DateAdded:</div>
                    <div class="col-md-8">@classess.DateAdded</div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4 font-weight-bold">Status:</div>
                    <div class="col-md-8">@classess.Status</div>
                </div>

                <div class="row">
                    <div class="col text-right">
                        <a href="/classes/update/@classess.Id"><button class="btn btn-primary">Edit</button></a>
                        <a href="/classes/Delete/@classess.Id"><button  class="btn btn-danger ml-2">Delete</button></a>
                    </div>
                </div>
            }
            else
            {
                <p>Loading class details...</p>
            }
        </div>
    </div>
</div>

<!-- Optional: Use Bootstrap for responsiveness and pleasant look -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

@code{
    [Parameter] 
    public int Id{get;set;}
    private GetClassDTO? classess;
    protected override async Task OnParametersSetAsync()
    {
        classess = await ClassService.GetClassByIdAsync(Id);
    }
}