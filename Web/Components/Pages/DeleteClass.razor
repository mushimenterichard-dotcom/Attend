@page "/classes/delete/{id:int}"
@inject NavigationManager Navigation
@using Application.Services.ClassServices
@using Application.DTOs
@rendermode InteractiveServer
@inject IClassService ClassService
@inject NavigationManager Navigation

<div class="container mt-5">
    <EditForm Model="classesss" OnValidSubmit="RemoveClass">
        <div class="form-group">
        <label class="btn btn-danger">Are you sure you want to delete this class?</label>
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/classes" class="btn btn-secondary">Cancel</a>
        </div>
    </EditForm>
</div>
@code{
    [Parameter]
    public int Id { get; set; }
    private GetClassDTO? ExistingClass;
    private DeleteClassDTO  classesss = new ();
    protected override void OnParametersSet()
    {
       ExistingClass = ClassService.GetClassById(Id);
        if (ExistingClass != null)
        {
            classesss.Id = ExistingClass.Id;
        }
    }
    private void RemoveClass()
    {
        if (classesss != null)
        {
            ClassService.DeleteClass(classesss);
            Navigation.NavigateTo("/classes");
        }
    }
}